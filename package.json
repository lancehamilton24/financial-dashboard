{
  "name": "financial-dashboard",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "pnpm --recursive --if-present build",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "test": "pnpm --recursive --if-present test",
    "lint": "pnpm --recursive --if-present lint",
    "format:check": "pnpm --recursive --if-present format:check",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
